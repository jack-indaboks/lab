{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "task": {
      "*": "deny",
      "lab-*": "allow"
    },
    "bash": {
      "*": "ask"
    },
    "edit": {
      "*": "ask"
    },
    "external_directory": {
      "*": "deny"
    }
  }
}